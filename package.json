{
  "name": "unified-memory-architecture-for-claude-code-and-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Unified Memory Architecture for Claude Code and Codex — a local-first, auditable unified memory layer (SQLite/FTS5 + Memory MCP) plus a Claude+Codex dual-agent council (independent analysis → cross-review → synthesis).",
  "engines": {
    "node": ">=22.6"
  },
  "bin": {
    "umem": "src/cli/index.ts",
    "ccc": "src/cli/ccc.ts"
  },
  "scripts": {
    "umem": "node --experimental-strip-types --no-warnings src/cli/index.ts",
    "mcp": "node --experimental-strip-types --no-warnings src/mcp/server.ts",
    "test": "node --experimental-strip-types --no-warnings --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "stream-chain": "^2.2.5",
    "stream-json": "^1.9.1",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "@types/stream-json": "^1.7.8",
    "typescript": "^5.7.0"
  }
}
